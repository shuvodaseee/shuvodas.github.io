<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shuvo Das | Fire Protection Engineer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --brand: #E63A1E;
  --brand-dark: #B02C14;
  --brand-light: #FF6347;
  --steel: #4A4A4A;
  --muted: #777;
  --ghost: #C0C0C0;
  --line: rgba(255,255,255,0.07);
  --bg: #0A0A0A;
  --bg-2: #111111;
  --bg-3: #1A1A1A;
  --bg-4: #222222;
  --white: #FFFFFF;
  --font-display: 'Bebas Neue', sans-serif;
  --font-body: 'DM Sans', sans-serif;
  --font-mono: 'DM Mono', monospace;
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--white);
  font-family: var(--font-body);
  font-size: 16px;
  line-height: 1.6;
  overflow-x: hidden;
  cursor: none;
}
#cursor {
  position: fixed; width: 12px; height: 12px;
  background: var(--brand); border-radius: 50%;
  pointer-events: none; z-index: 9999;
  transform: translate(-50%, -50%);
  transition: width 0.3s, height 0.3s, background 0.3s;
}
#cursor-ring {
  position: fixed; width: 36px; height: 36px;
  border: 1px solid rgba(230,58,30,0.5); border-radius: 50%;
  pointer-events: none; z-index: 9998;
  transform: translate(-50%, -50%);
  transition: width 0.3s, height 0.3s, opacity 0.3s;
}
#fire-canvas {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  pointer-events: none; z-index: 0; opacity: 0.35;
}
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: space-between; align-items: center;
  padding: 0 5vw; height: 64px;
  background: rgba(10,10,10,0.92);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--line);
  animation: navIn 0.8s cubic-bezier(0.16,1,0.3,1) forwards;
}
@keyframes navIn { from { transform: translateY(-100%); opacity: 0; } to { transform: none; opacity: 1; } }
.nav-logo {
  font-family: var(--font-display); font-size: 26px; letter-spacing: 1px;
  color: var(--white); text-decoration: none; position: relative;
}
.nav-logo span { color: var(--brand); }
.nav-logo::after {
  content: ''; position: absolute; bottom: -2px; left: 0;
  width: 0; height: 2px; background: var(--brand); transition: width 0.3s;
}
.nav-logo:hover::after { width: 100%; }
.nav-links { display: flex; gap: 32px; list-style: none; }
.nav-links a {
  font-family: var(--font-mono); font-size: 12px; font-weight: 500;
  color: var(--ghost); text-decoration: none; letter-spacing: 0.06em;
  position: relative; transition: color 0.2s;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -3px; left: 0;
  width: 0; height: 1px; background: var(--brand); transition: width 0.25s;
}
.nav-links a:hover { color: var(--white); }
.nav-links a:hover::after { width: 100%; }
.nav-cta {
  background: var(--brand) !important; color: var(--white) !important;
  padding: 8px 20px; border-radius: 3px;
  transition: background 0.2s, transform 0.15s, box-shadow 0.2s !important;
}
.nav-cta:hover { background: var(--brand-light) !important; transform: translateY(-1px) !important; box-shadow: 0 4px 20px rgba(230,58,30,0.4) !important; }
.nav-cta::after { display: none !important; }
#hero {
  min-height: 100vh;
  display: grid; grid-template-columns: 1fr 1fr;
  align-items: center; padding: 120px 5vw 80px; gap: 60px;
  position: relative; z-index: 1; overflow: hidden;
}
#hero::before {
  content: ''; position: absolute; top: 0; right: 0;
  width: 55%; height: 100%;
  background: radial-gradient(ellipse at 70% 50%, rgba(230,58,30,0.09) 0%, transparent 60%);
  pointer-events: none; animation: heroGlow 4s ease-in-out infinite alternate;
}
@keyframes heroGlow { from { opacity: 0.4; } to { opacity: 1; } }
.h-anim { opacity: 0; transform: translateY(32px); }
.h-anim.go { animation: fadeUp 0.7s cubic-bezier(0.16,1,0.3,1) forwards; }
@keyframes fadeUp { to { opacity: 1; transform: none; } }
.hero-tag {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-mono); font-size: 12px;
  color: var(--brand); letter-spacing: 0.12em;
  border: 1px solid rgba(230,58,30,0.35);
  padding: 6px 14px; border-radius: 2px; margin-bottom: 24px;
}
.hero-tag::before {
  content: ''; width: 6px; height: 6px;
  border-radius: 50%; background: var(--brand);
  animation: dotPulse 1.8s ease-in-out infinite;
}
@keyframes dotPulse { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:0.2; transform:scale(0.6); } }
h1.hero-name {
  font-family: var(--font-display);
  font-size: clamp(60px, 8vw, 108px);
  line-height: 0.9; letter-spacing: 2px; color: var(--white); margin-bottom: 8px;
}
.name-word { display: inline-block; opacity: 0; transform: translateY(40px) skewY(3deg); }
.name-word.go { animation: nameIn 0.8s cubic-bezier(0.16,1,0.3,1) forwards; }
@keyframes nameIn { to { opacity:1; transform:none; } }
h1.hero-name em { color: var(--brand); font-style: normal; display: block; }
.hero-title {
  font-size: 17px; font-weight: 300; color: var(--ghost);
  margin-bottom: 20px; letter-spacing: 0.02em; min-height: 28px;
}
.typed-text { border-right: 2px solid var(--brand); padding-right: 2px; }
.hero-desc { font-size: 15px; color: var(--steel); line-height: 1.8; max-width: 460px; margin-bottom: 36px; }
.hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
.btn-primary {
  background: var(--brand); color: var(--white);
  padding: 14px 32px; border-radius: 3px;
  font-family: var(--font-mono); font-size: 13px; font-weight: 500;
  letter-spacing: 0.08em; text-decoration: none;
  transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  display: inline-block; position: relative; overflow: hidden;
}
.btn-primary::before {
  content: ''; position: absolute; top: 50%; left: -100%;
  width: 100%; height: 100%; background: rgba(255,255,255,0.12);
  transform: translateY(-50%) skewX(-20deg); transition: left 0.45s;
}
.btn-primary:hover::before { left: 150%; }
.btn-primary:hover { background: var(--brand-light); transform: translateY(-2px); box-shadow: 0 6px 24px rgba(230,58,30,0.45); }
.btn-ghost {
  border: 1px solid rgba(255,255,255,0.18); color: var(--white);
  padding: 14px 32px; border-radius: 3px;
  font-family: var(--font-mono); font-size: 13px; font-weight: 500;
  letter-spacing: 0.08em; text-decoration: none;
  transition: border-color 0.2s, background 0.2s, transform 0.15s; display: inline-block;
}
.btn-ghost:hover { border-color: var(--brand); background: rgba(230,58,30,0.07); transform: translateY(-2px); }
.hero-stats {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: 8px; overflow: hidden;
}
.stat-cell { background: var(--bg-2); padding: 24px 16px; text-align: center; transition: background 0.3s; }
.stat-cell:hover { background: var(--bg-3); }
.stat-num { font-family: var(--font-display); font-size: 46px; color: var(--brand); line-height: 1; margin-bottom: 6px; }
.stat-label { font-family: var(--font-mono); font-size: 10px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }
.hero-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 28px; }
.badge {
  font-family: var(--font-mono); font-size: 11px;
  background: var(--bg-3); color: var(--ghost);
  border: 1px solid rgba(255,255,255,0.06);
  padding: 5px 12px; border-radius: 2px; letter-spacing: 0.05em;
  transition: border-color 0.2s, color 0.2s, transform 0.2s; cursor: default;
}
.badge:hover { border-color: var(--brand); color: var(--brand); transform: translateY(-2px); }
section { padding: 100px 5vw; position: relative; z-index: 1; }
.section-label { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.15em; color: var(--brand); text-transform: uppercase; margin-bottom: 12px; }
h2.section-title { font-family: var(--font-display); font-size: clamp(40px, 5vw, 64px); letter-spacing: 1px; line-height: 1; margin-bottom: 16px; }
.section-sub { font-size: 15px; color: var(--steel); max-width: 540px; line-height: 1.8; margin-bottom: 60px; }
.slash-divider { display: flex; align-items: center; gap: 16px; margin-bottom: 60px; }
.slash-divider::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.05); }
.reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1); }
.reveal.visible { opacity: 1; transform: none; }
.reveal-left { opacity: 0; transform: translateX(-40px); transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1); }
.reveal-left.visible { opacity: 1; transform: none; }
.reveal-right { opacity: 0; transform: translateX(40px); transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1); }
.reveal-right.visible { opacity: 1; transform: none; }
#expertise { background: var(--bg-2); }
.expertise-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 2px; background: rgba(255,255,255,0.03); border-radius: 8px; overflow: hidden;
}
.expertise-card {
  background: var(--bg-2); padding: 36px 30px;
  border-bottom: 3px solid transparent;
  transition: border-color 0.3s, background 0.3s, transform 0.3s;
  cursor: default; opacity: 0; transform: translateY(30px);
}
.expertise-card.card-in { animation: cardIn 0.6s cubic-bezier(0.16,1,0.3,1) forwards; }
@keyframes cardIn { to { opacity:1; transform:none; } }
.expertise-card:hover { border-color: var(--brand); background: var(--bg-3); transform: translateY(-4px); }
.exp-icon {
  width: 44px; height: 44px;
  background: rgba(230,58,30,0.1); border: 1px solid rgba(230,58,30,0.2);
  border-radius: 8px; display: flex; align-items: center; justify-content: center;
  margin-bottom: 18px; font-size: 20px; transition: background 0.3s, transform 0.3s;
}
.expertise-card:hover .exp-icon { background: rgba(230,58,30,0.22); transform: scale(1.1) rotate(-5deg); }
.expertise-card h3 { font-size: 15px; font-weight: 600; margin-bottom: 10px; }
.expertise-card p { font-size: 13px; color: var(--steel); line-height: 1.6; }
.skill-bar { margin-bottom: 20px; }
.skill-bar-header { display: flex; justify-content: space-between; margin-bottom: 6px; }
.skill-bar-label { font-family: var(--font-mono); font-size: 11px; color: var(--ghost); letter-spacing: 0.06em; }
.skill-bar-pct { font-family: var(--font-mono); font-size: 11px; color: var(--brand); }
.skill-bar-track { height: 3px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden; }
.skill-bar-fill { height: 100%; background: var(--brand); border-radius: 2px; width: 0; transition: width 1.2s cubic-bezier(0.16,1,0.3,1); }
#courses { background: var(--bg); }
.courses-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
.course-card {
  background: var(--bg-2); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; overflow: hidden;
  transition: border-color 0.3s, transform 0.35s, box-shadow 0.35s;
  opacity: 0; transform: translateY(40px);
}
.course-card.card-in { animation: cardIn 0.6s cubic-bezier(0.16,1,0.3,1) forwards; }
.course-card:hover { border-color: var(--brand); transform: translateY(-6px); box-shadow: 0 16px 40px rgba(0,0,0,0.4); }
.course-thumb {
  height: 160px; display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
  font-family: var(--font-display); font-size: 80px; letter-spacing: 2px;
  color: rgba(255,255,255,0.04); background: var(--bg-3); transition: color 0.4s;
}
.course-card:hover .course-thumb { color: rgba(230,58,30,0.09); }
.course-thumb-label {
  position: absolute; top: 14px; left: 14px;
  font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em;
  padding: 4px 10px; border-radius: 2px; background: var(--brand); color: var(--white); z-index: 1;
}
.course-body { padding: 24px; }
.course-body h3 { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
.course-body p { font-size: 13px; color: var(--steel); line-height: 1.65; margin-bottom: 18px; }
.course-meta { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 16px; }
.course-level { font-family: var(--font-mono); font-size: 10px; color: var(--muted); letter-spacing: 0.08em; }
.course-cta { font-family: var(--font-mono); font-size: 12px; color: var(--brand); text-decoration: none; letter-spacing: 0.05em; display: flex; align-items: center; gap: 6px; transition: gap 0.2s, color 0.2s; }
.course-cta:hover { gap: 12px; color: var(--brand-light); }
#tutorials { background: var(--bg-2); }
.tutorials-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
.tutorial-list { display: flex; flex-direction: column; gap: 2px; }
.tutorial-item {
  display: flex; gap: 20px; align-items: flex-start;
  padding: 20px; border-radius: 6px;
  transition: background 0.25s, transform 0.25s; cursor: pointer; border: 1px solid transparent;
}
.tutorial-item:hover { background: var(--bg-3); border-color: rgba(255,255,255,0.05); transform: translateX(6px); }
.tut-num { font-family: var(--font-display); font-size: 30px; color: rgba(230,58,30,0.22); line-height: 1; min-width: 34px; padding-top: 2px; transition: color 0.25s; }
.tutorial-item:hover .tut-num { color: var(--brand); }
.tut-content h4 { font-size: 14px; font-weight: 500; margin-bottom: 5px; }
.tut-content p { font-size: 12px; color: var(--steel); }
.tut-type { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; padding: 3px 8px; border-radius: 2px; margin-top: 8px; display: inline-block; }
.tut-video { background: rgba(230,58,30,0.1); color: var(--brand); }
.tut-written { background: rgba(255,255,255,0.05); color: var(--ghost); }
.tutorial-cta-panel {
  background: var(--bg-3); border: 1px solid rgba(230,58,30,0.15);
  border-radius: 8px; padding: 40px 32px;
  display: flex; flex-direction: column; gap: 20px;
  position: sticky; top: 90px;
  transition: border-color 0.3s, box-shadow 0.3s;
}
.tutorial-cta-panel:hover { border-color: rgba(230,58,30,0.4); box-shadow: 0 0 40px rgba(230,58,30,0.05); }
.tcp-title { font-family: var(--font-display); font-size: 36px; line-height: 1.05; }
.tcp-title span { color: var(--brand); }
.tcp-desc { font-size: 13px; color: var(--steel); line-height: 1.7; }
#linkedin { background: var(--bg); }
.linkedin-wrapper { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.li-card {
  background: var(--bg-2); border: 1px solid rgba(255,255,255,0.07); border-radius: 12px; overflow: hidden;
  transition: transform 0.4s, box-shadow 0.4s;
}
.li-card:hover { transform: translateY(-6px) rotate(-0.5deg); box-shadow: 0 20px 60px rgba(0,0,0,0.5); }
.li-card-header {
  height: 120px; background: linear-gradient(135deg, #0f1929 0%, #1a2a42 50%, #0f1929 100%);
  position: relative; overflow: hidden;
}
.li-card-header::before {
  content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
  background: radial-gradient(ellipse at 60% 60%, rgba(0,119,181,0.15) 0%, transparent 60%);
  animation: liGlow 3s ease-in-out infinite alternate;
}
@keyframes liGlow { from { transform: scale(1); } to { transform: scale(1.1); } }
.li-card-header::after { content: 'in'; position: absolute; right: 20px; top: 16px; font-family: var(--font-display); font-size: 52px; color: rgba(255,255,255,0.05); }
.li-avatar {
  width: 80px; height: 80px; border-radius: 50%;
  background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display); font-size: 34px; color: var(--white);
  border: 3px solid var(--bg-2); position: absolute; bottom: -40px; left: 28px;
  transition: transform 0.3s; box-shadow: 0 4px 20px rgba(230,58,30,0.3);
}
.li-card:hover .li-avatar { transform: scale(1.06); }
.li-card-body { padding: 52px 28px 28px; }
.li-name { font-size: 19px; font-weight: 600; margin-bottom: 4px; }
.li-sub { font-size: 13px; color: var(--steel); margin-bottom: 18px; }
.li-pills { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 22px; }
.li-pill { font-family: var(--font-mono); font-size: 10px; background: var(--bg-3); color: var(--ghost); border: 1px solid rgba(255,255,255,0.05); padding: 4px 11px; border-radius: 40px; transition: border-color 0.2s, color 0.2s; }
.li-pill:hover { border-color: var(--brand); color: var(--brand); }
.li-connect-btn { display: inline-flex; align-items: center; gap: 8px; background: #0077B5; color: var(--white); padding: 11px 26px; border-radius: 24px; font-size: 14px; font-weight: 600; text-decoration: none; transition: background 0.2s, transform 0.15s, box-shadow 0.2s; }
.li-connect-btn:hover { background: #005e8f; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,119,181,0.4); }
.li-facts { display: flex; flex-direction: column; gap: 12px; margin-top: 24px; }
.li-fact { display: flex; align-items: center; gap: 14px; font-size: 14px; color: var(--ghost); padding: 12px 16px; border-radius: 6px; border: 1px solid transparent; transition: background 0.2s, border-color 0.2s, transform 0.2s; }
.li-fact:hover { background: var(--bg-2); border-color: rgba(255,255,255,0.05); transform: translateX(4px); }
.li-fact-icon { width: 32px; height: 32px; background: rgba(230,58,30,0.1); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }
#contact { background: var(--bg-2); }
.contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
.contact-form { display: flex; flex-direction: column; gap: 16px; }
label { font-family: var(--font-mono); font-size: 11px; color: var(--muted); letter-spacing: 0.1em; display: block; margin-bottom: 6px; }
input[type=text], input[type=email], textarea, select {
  width: 100%; background: var(--bg-3); border: 1px solid rgba(255,255,255,0.07); border-radius: 5px;
  padding: 12px 16px; color: var(--white); font-family: var(--font-body); font-size: 15px;
  outline: none; transition: border-color 0.25s, box-shadow 0.25s;
}
input[type=text]:focus, input[type=email]:focus, textarea:focus, select:focus { border-color: var(--brand); box-shadow: 0 0 0 3px rgba(230,58,30,0.1); }
textarea { min-height: 140px; resize: vertical; }
select { cursor: pointer; }
select option { background: var(--bg-3); }
.submit-btn {
  background: var(--brand); color: var(--white); padding: 14px 36px; border-radius: 3px; border: none; cursor: pointer;
  font-family: var(--font-mono); font-size: 13px; font-weight: 500; letter-spacing: 0.08em;
  transition: background 0.2s, transform 0.15s, box-shadow 0.2s; width: fit-content; position: relative; overflow: hidden;
}
.submit-btn::before { content: ''; position: absolute; top: 50%; left: -100%; width: 100%; height: 100%; background: rgba(255,255,255,0.1); transform: translateY(-50%) skewX(-20deg); transition: left 0.4s; }
.submit-btn:hover::before { left: 150%; }
.submit-btn:hover { background: var(--brand-light); transform: translateY(-2px); box-shadow: 0 6px 24px rgba(230,58,30,0.4); }
.contact-info h3 { font-family: var(--font-display); font-size: 42px; line-height: 1.05; margin-bottom: 16px; }
.contact-info h3 span { color: var(--brand); }
.contact-info p { font-size: 14px; color: var(--steel); line-height: 1.8; margin-bottom: 12px; }
.contact-channels { display: flex; flex-direction: column; gap: 12px; margin-top: 24px; }
.channel { display: flex; align-items: center; gap: 16px; padding: 16px 18px; background: var(--bg-3); border-radius: 8px; border: 1px solid rgba(255,255,255,0.04); transition: border-color 0.25s, transform 0.25s; }
.channel:hover { border-color: rgba(230,58,30,0.3); transform: translateX(6px); }
.channel-icon { font-size: 18px; width: 32px; text-align: center; }
.channel-label { font-family: var(--font-mono); font-size: 10px; color: var(--muted); display: block; letter-spacing: 0.08em; }
.channel-val { font-size: 14px; color: var(--white); }
.tag-strip { overflow: hidden; padding: 16px 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg-2); position: relative; z-index: 1; }
.tag-strip-track { display: flex; width: max-content; animation: stripScroll 28s linear infinite; }
