<script>
/* CURSOR */
const cur = document.getElementById('cursor');
const ring = document.getElementById('cursor-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
(function anim(){rx+=(mx-rx)*0.12;ry+=(my-ry)*0.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(anim);})();
document.addEventListener('mouseover',e=>{if(e.target.closest('a,button')){cur.style.width='20px';cur.style.height='20px';ring.style.width='52px';ring.style.height='52px';}});
document.addEventListener('mouseout',e=>{if(e.target.closest('a,button')){cur.style.width='12px';cur.style.height='12px';ring.style.width='36px';ring.style.height='36px';}});

/* FIRE CANVAS */
const cv=document.getElementById('fire-canvas'),c=cv.getContext('2d');
function resize(){cv.width=innerWidth;cv.height=innerHeight;}
resize();window.addEventListener('resize',resize);
const pts=[];
class P{
  constructor(){this.rs();}
  rs(){this.x=Math.random()*cv.width;this.y=cv.height+10;this.vx=(Math.random()-.5)*.8;this.vy=-(Math.random()*2+.7);this.l=1;this.d=Math.random()*.004+.002;this.s=Math.random()*3+1;this.h=Math.random()*28+4;}
  tick(){this.x+=this.vx;this.y+=this.vy;this.vx+=(Math.random()-.5)*.05;this.l-=this.d;this.s*=.999;if(this.l<=0)this.rs();}
  draw(){c.save();c.globalAlpha=this.l*.55;c.fillStyle=`hsl(${this.h},100%,${50+this.l*30}%)`;c.shadowColor=c.fillStyle;c.shadowBlur=5;c.beginPath();c.arc(this.x,this.y,this.s,0,Math.PI*2);c.fill();c.restore();}
}
for(let i=0;i<140;i++){const p=new P();p.y=Math.random()*cv.height;p.l=Math.random();pts.push(p);}
(function loop(){c.clearRect(0,0,cv.width,cv.height);pts.forEach(p=>{p.tick();p.draw();});requestAnimationFrame(loop);})();

/* HERO ENTRANCE */
window.addEventListener('load',()=>{
  document.querySelectorAll('.h-anim').forEach((el,i)=>setTimeout(()=>el.classList.add('go'),i*150+200));
  document.querySelectorAll('.name-word').forEach((el,i)=>setTimeout(()=>el.classList.add('go'),i*150+400));
  setTimeout(()=>{const h=document.getElementById('hero-right');h.style.opacity='1';h.style.transform='none';},700);
  typeNext();
  setTimeout(countUp,900);
});

/* TYPEWRITER */
const lines=['Fire Protection & Detection Systems Specialist','NFPA 13 · NFPA 20 · BNBC Certified','Hydraulic Calculations Expert','AutoCAD Fire System Designer'];
let li=0,ci=0,del=false;
function typeNext(){
  const el=document.getElementById('typed'),full=lines[li];
  if(!del){el.textContent=full.slice(0,++ci);if(ci===full.length){del=true;setTimeout(typeNext,2200);}else setTimeout(typeNext,55);}
  else{el.textContent=full.slice(0,--ci);if(ci===0){del=false;li=(li+1)%lines.length;setTimeout(typeNext,300);}else setTimeout(typeNext,28);}
}

/* COUNT UP */
function countUp(){
  document.querySelectorAll('.stat-num[data-count]').forEach(el=>{
    const t=parseInt(el.dataset.count);let n=0;const s=t/40;
    const iv=setInterval(()=>{n+=s;if(n>=t){el.textContent=t+'+';clearInterval(iv);}else el.textContent=Math.floor(n)+(n>0?'+':'');},40);
  });
}

/* SCROLL REVEAL */
const ro=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');ro.unobserve(e.target);}}),{threshold:0.08});
document.querySelectorAll('.reveal,.reveal-left,.reveal-right').forEach(el=>ro.observe(el));

/* CARD STAGGER */
const co=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.querySelectorAll('.expertise-card,.course-card').forEach((c,i)=>setTimeout(()=>c.classList.add('card-in'),i*100));co.unobserve(e.target);}}),{threshold:0.1});
document.querySelectorAll('.expertise-grid,.courses-grid').forEach(g=>co.observe(g));

/* SKILL BARS */
const bo=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.querySelectorAll('.skill-bar-fill').forEach((b,i)=>setTimeout(()=>b.style.width=b.dataset.width+'%',i*120));bo.unobserve(e.target);}}),{threshold:0.3});
document.querySelectorAll('section').forEach(s=>bo.observe(s));

/* NAV HIGHLIGHT */
const secs=document.querySelectorAll('section[id]'),nls=document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{let cur='';secs.forEach(s=>{if(scrollY>=s.offsetTop-110)cur=s.id;});nls.forEach(a=>{a.style.color=a.getAttribute('href')==='#'+cur?'var(--white)':'';});},{passive:true});
</script>
